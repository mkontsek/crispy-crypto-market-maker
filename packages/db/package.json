{
    "name": "@crispy/db",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "build": "prisma generate",
        "lint": "echo 'db lint skipped'",
        "typecheck": "pnpm run db:generate && tsc --noEmit -p tsconfig.json",
        "db:generate": "prisma generate",
        "db:dev:migrate": "prisma db push",
        "db:prod:migrate": "prisma migrate deploy",
        "db:dev:reset": "prisma db push --force-reset",
        "db:dev:seed": "prisma db seed",
        "db:prod:seed": "prisma db seed",
        "db:seed": "prisma db seed",
        "prisma:generate": "pnpm run db:generate",
        "prisma:push": "pnpm run db:dev:migrate",
        "prisma:migrate": "pnpm run db:prod:migrate"
    },
    "prisma": {
        "seed": "node prisma/seed.mjs"
    },
    "dependencies": {
        "@prisma/adapter-pg": "7.4.2",
        "@prisma/client": "7.4.2",
        "dotenv": "17.3.1",
        "pg": "8.20.0"
    },
    "devDependencies": {
        "@types/node": "25.4.0",
        "prisma": "7.4.2",
        "typescript": "5.9.3"
    }
}
