{
  "name": "@crispy/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "typecheck": "pnpm run generate && tsc --noEmit -p tsconfig.json",
    "dev:migrate": "prisma db push",
    "prod:migrate": "PRISMA_ENV=production prisma migrate deploy",
    "dev:up": "docker compose -f docker-compose.yml up -d db && pnpm run dev:migrate",
    "dev:stop": "docker compose -f docker-compose.yml stop db",
    "dev:reset": "docker compose -f docker-compose.yml down -v && docker compose -f docker-compose.yml up -d db && pnpm run dev:migrate && pnpm run dev:seed",
    "dev:seed": "prisma db seed",
    "prod:seed": "PRISMA_ENV=production prisma db seed",
    "postinstall": "pnpm run generate"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "dotenv": "17.3.1",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@types/node": "25.4.0",
    "prisma": "7.4.2",
    "typescript": "5.9.3"
  }
}
