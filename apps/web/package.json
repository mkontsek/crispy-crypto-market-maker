{
  "name": "@crispy/web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev --port 3008",
    "build": "pnpm run db:generate && next build",
    "start": "next start --port 3008",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "pnpm --filter @crispy/db prisma:generate",
    "db:push": "pnpm --filter @crispy/db prisma:push"
  },
  "dependencies": {
    "@crispy/db": "workspace:*",
    "@crispy/shared": "workspace:*",
    "@tanstack/react-query": "5.90.21",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "12.38.0",
    "immer": "11.1.4",
    "leaflet": "1.9.4",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "5.0.0",
    "tailwind-merge": "3.5.0",
    "ws": "8.19.0",
    "zod": "4.3.6",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/react": "16.3.0",
    "@types/leaflet": "1.9.21",
    "@types/node": "25.4.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "eslint": "9.39.2",
    "eslint-config-next": "16.1.6",
    "jsdom": "27.0.1",
    "postcss": "8.5.8",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  }
}
